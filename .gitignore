# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel

# claude code local settings
.claude/

# 매출 파이썬 원본(참고용, 평문 SMTP 비밀번호 포함 → 절대 커밋 금지)
/매출리포트_*.py

# 내부 진단/시드 스크립트(로컬 전용, 커밋 금지)
# 단 sync-design-tokens 는 빌드(package.json build)가 실행하므로 반드시 커밋 — 예외 처리
/scripts/*
!/scripts/sync-design-tokens.mjs

# 외부 API 참고 문서(원문, 대용량)
/API Reference_*.txt
/Release Notes_*.txt

# 임시 진단 스크립트(자격증명 포함 가능) — 커밋 금지
_*.mjs
